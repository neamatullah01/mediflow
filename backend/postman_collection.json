{
  "info": {
    "name": "MediFlow Automated API Collection",
    "description": "Comprehensive automated testing suite for all MediFlow modules. Includes sequential execution, authentication handling, and ID extraction between requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "pharmacistEmail", "value": "test_pharmacist@mediflow.com", "type": "string" },
    { "key": "adminEmail", "value": "admin@mediflow.com", "type": "string" },
    { "key": "adminCookie", "value": "", "type": "string" },
    { "key": "pharmacistCookie", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "pharmacyId", "value": "", "type": "string" },
    { "key": "drugId", "value": "", "type": "string" },
    { "key": "inventoryId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "blogId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth Module",
      "description": "Handles registration and login to populate cookies.",
      "item": [
        {
          "name": "Register Pharmacist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.user) {",
                  "    pm.environment.set('userId', jsonData.data.user.id);",
                  "    if (jsonData.data.user.pharmacyId) pm.environment.set('pharmacyId', jsonData.data.user.pharmacyId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Pharmacist\",\n  \"email\": \"{{pharmacistEmail}}\",\n  \"password\": \"Password123!\",\n  \"phone\": \"01700000000\",\n  \"pharmacyName\": \"Test Automated Pharmacy\",\n  \"licenseNumber\": \"LIC-AUTO-001\",\n  \"address\": \"Automated Street\"\n}"
            }
          }
        },
        {
          "name": "Login Pharmacist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var cookie = pm.cookies.get('better-auth.session_token') || pm.response.headers.get('Set-Cookie');",
                  "if (cookie) pm.environment.set('pharmacistCookie', cookie);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{pharmacistEmail}}\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var cookie = pm.cookies.get('better-auth.session_token') || pm.response.headers.get('Set-Cookie');",
                  "if (cookie) pm.environment.set('adminCookie', cookie);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"Admin@1234\"\n}"
            }
          }
        },
        {
          "name": "Get Current Profile (Me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "2. Admin Management",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "better-auth.session_token={{adminCookie}}" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Get All Pharmacies",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "better-auth.session_token={{adminCookie}}" }],
            "url": { "raw": "{{baseUrl}}/pharmacies", "host": ["{{baseUrl}}"], "path": ["pharmacies"] }
          }
        },
        {
          "name": "Admin Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "better-auth.session_token={{adminCookie}}" }],
            "url": { "raw": "{{baseUrl}}/admin/stats", "host": ["{{baseUrl}}"], "path": ["admin", "stats"] }
          }
        }
      ]
    },
    {
      "name": "3. Master Drug Catalogue",
      "item": [
        {
          "name": "Create Drug (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) pm.environment.set('drugId', jsonData.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{adminCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/drugs", "host": ["{{baseUrl}}"], "path": ["drugs"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Automated API Drug\",\n  \"genericName\": \"Test Generic\",\n  \"category\": \"ANTIBIOTIC\",\n  \"dosageForm\": \"TABLET\",\n  \"description\": \"Created via Postman API Automation\",\n  \"uses\": [\"Headache\", \"Fever\"],\n  \"sideEffects\": [\"Nausea\"],\n  \"contraindications\": [\"Allergy\"],\n  \"manufacturer\": \"PharmaTech\"\n}"
            }
          }
        },
        {
          "name": "Get All Drugs",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/drugs", "host": ["{{baseUrl}}"], "path": ["drugs"] }
          }
        },
        {
          "name": "Get Drug By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/drugs/{{drugId}}", "host": ["{{baseUrl}}"], "path": ["drugs", "{{drugId}}"] }
          }
        }
      ]
    },
    {
      "name": "4. Inventory Management",
      "item": [
        {
          "name": "Add Inventory Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) pm.environment.set('inventoryId', jsonData.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/inventory", "host": ["{{baseUrl}}"], "path": ["inventory"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"drugId\": \"{{drugId}}\",\n  \"quantity\": 100,\n  \"unitPrice\": 12.5,\n  \"expiryDate\": \"2030-12-31T00:00:00Z\",\n  \"batchNumber\": \"B-001\",\n  \"reorderLevel\": 20\n}"
            }
          }
        },
        {
          "name": "Get Inventory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }],
            "url": { "raw": "{{baseUrl}}/inventory", "host": ["{{baseUrl}}"], "path": ["inventory"] }
          }
        },
        {
          "name": "Get Low Stock Alerts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }],
            "url": { "raw": "{{baseUrl}}/inventory/alerts/low-stock", "host": ["{{baseUrl}}"], "path": ["inventory", "alerts", "low-stock"] }
          }
        },
        {
          "name": "Export Inventory CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }],
            "url": { "raw": "{{baseUrl}}/inventory/export/csv", "host": ["{{baseUrl}}"], "path": ["inventory", "export", "csv"] }
          }
        }
      ]
    },
    {
      "name": "5. Dispensing & Orders",
      "item": [
        {
          "name": "Record Dispensing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status is 201', function () { pm.response.to.have.status(201); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/dispensing", "host": ["{{baseUrl}}"], "path": ["dispensing"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inventoryItemId\": \"{{inventoryId}}\",\n  \"quantityDispensed\": 5,\n  \"patientName\": \"John Doe\"\n}"
            }
          }
        },
        {
          "name": "Get Dispensing Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }],
            "url": { "raw": "{{baseUrl}}/dispensing", "host": ["{{baseUrl}}"], "path": ["dispensing"] }
          }
        },
        {
          "name": "Create Supplier Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) pm.environment.set('orderId', jsonData.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplierName\": \"Global Med Supplies\",\n  \"lineItems\": [\n    {\n      \"drugId\": \"{{drugId}}\",\n      \"quantity\": 50,\n      \"unitPrice\": 10.0\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Receive Order (Auto-Updates Inventory)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status is 200', function () { pm.response.to.have.status(200); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["orders", "{{orderId}}", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"RECEIVED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "6. AI Services",
      "item": [
        {
          "name": "Drug Interaction Check",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/ai/check-interactions", "host": ["{{baseUrl}}"], "path": ["ai", "check-interactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"drugs\": [\"Aspirin\", \"Warfarin\"]\n}"
            }
          }
        },
        {
          "name": "Demand Forecast",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/ai/demand-forecast", "host": ["{{baseUrl}}"], "path": ["ai", "demand-forecast"] },
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "AI Auto-Tag Drug (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{adminCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/ai/tag-drug", "host": ["{{baseUrl}}"], "path": ["ai", "tag-drug"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"drugName\": \"Amoxicillin 500mg\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "7. Blog & Reviews",
      "item": [
        {
          "name": "Submit Drug Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{pharmacistCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/drugs/{{drugId}}/reviews", "host": ["{{baseUrl}}"], "path": ["drugs", "{{drugId}}", "reviews"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent drug, highly effective.\"\n}"
            }
          }
        },
        {
          "name": "Create Blog Post (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) pm.environment.set('blogId', jsonData.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{adminCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/blog", "host": ["{{baseUrl}}"], "path": ["blog"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Automation Test Post\",\n  \"excerpt\": \"This is an automated post generated by Postman.\",\n  \"content\": \"<p>Automated content here.</p>\",\n  \"category\": \"Updates\",\n  \"tags\": [\"automation\", \"testing\"]\n}"
            }
          }
        },
        {
          "name": "Publish Blog Post",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "better-auth.session_token={{adminCookie}}" }
            ],
            "url": { "raw": "{{baseUrl}}/blog/{{blogId}}/publish", "host": ["{{baseUrl}}"], "path": ["blog", "{{blogId}}", "publish"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPublished\": true\n}"
            }
          }
        }
      ]
    }
  ]
}
